# ─── PSX Candle Pipeline Environment Variables ───
# Copy this file to .env and fill in real values.

# Path to the directory containing historical per-day SQLite .db files
LOCAL_HISTORICAL_DIR=/absolute/path/to/individual_dbs

# GitHub source for daily raw data
GITHUB_REPO=ahmerhkhan/psx-intraday
GITHUB_BRANCH=main
GITHUB_DATA_PATH=data/raw/
GITHUB_TOKEN=               # only needed if the repo is private

# PostgreSQL connection string
PG_DSN=postgresql://user:pass@localhost:5432/psx_intraday

# Set to "sqlite" to use local SQLite instead of PostgreSQL
DB_BACKEND=sqlite
# Path used when DB_BACKEND=sqlite
SQLITE_PATH=./psx_candles.db

# Raw file glob pattern (for CSV-based sources, not used for SQLite ingest)
RAW_FILE_GLOB=*.csv
